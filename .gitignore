# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# claude code local tooling
.claude/

# user-uploaded client logos (keep the folder, not its contents)
/public/uploads/*
!/public/uploads/.gitkeep

# private uploaded files (downloads) served via auth-gated route
/storage

# typescript
*.tsbuildinfo
next-env.d.ts
