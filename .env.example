# ── Database: Supabase (PostgreSQL) ──────────────────────────────
# Find these in your Supabase project: Settings → Database → Connection string.
#
# DATABASE_URL  = Transaction pooler (Supavisor), host ...pooler.supabase.com:6543
#                 Used by the app at runtime. Keep the pgbouncer flag.
# DIRECT_URL    = Direct connection, host db.<ref>.supabase.co:5432
#                 Used by Prisma for migrations only.
#
# Replace [PASSWORD] and the project ref with your own values.
DATABASE_URL="postgresql://postgres.<project-ref>:[PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<project-ref>:[PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ── Auth.js ──────────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET="replace-with-a-long-random-string"

# ── Initial admin user created by `npm run db:seed` ──────────────
SEED_ADMIN_EMAIL="admin@devanor.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="Devanor Admin"

# ── Zendesk Web Widget (customer portal support chat) ────────────
# Found in Zendesk: Admin Center → Channels → Web Widget → embed snippet,
# the value after `?key=` in https://static.zdassets.com/ekr/snippet.js?key=...
# Leave empty to show the fallback contact card instead of the chat widget.
NEXT_PUBLIC_ZENDESK_KEY=""
