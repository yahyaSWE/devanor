generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  CUSTOMER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         Role     @default(CUSTOMER)
  client       Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId     String?
  createdAt    DateTime @default(now())
}

model Client {
  id         String   @id @default(cuid())
  name       String
  logoUrl    String
  websiteUrl String
  users      User[]
  createdAt  DateTime @default(now())
}

model DemoRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  message   String?
  createdAt DateTime @default(now())
}
