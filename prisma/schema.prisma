generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  CUSTOMER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  title        String? // job title / role at the company, shown to support
  role         Role     @default(CUSTOMER)
  client       Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId     String?
  createdAt    DateTime @default(now())
}

model Client {
  id         String     @id @default(cuid())
  name       String
  logoUrl    String
  websiteUrl String
  active     Boolean    @default(true)
  showOnSite Boolean    @default(true)
  users      User[]
  downloads  Download[]
  tutorials  Tutorial[]
  licenses   License[]
  createdAt  DateTime   @default(now())
}

model DemoRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  phone     String?
  message   String?
  createdAt DateTime @default(now())
}

// A downloadable file (license file, script, document). Files are stored
// outside /public and served via an auth-gated route.
model Download {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String?
  fileName    String // original name, shown to the user
  storedName  String // name on disk under ./storage/uploads
  mimeType    String
  size        Int
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId    String? // null = available to all customers
  createdAt   DateTime @default(now())
}

// A gated tutorial / training resource (video or external link).
model Tutorial {
  id          String   @id @default(cuid())
  title       String
  description String?
  level       String   @default("Beginner")
  url         String
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId    String? // null = available to all customers
  createdAt   DateTime @default(now())
}

enum LicenseStatus {
  ACTIVE
  TRIAL
  EXPIRED
}

enum LicenseType {
  LICENSE
  MAINTENANCE
}

// A licensed module or a maintenance entry belonging to a client.
model License {
  id        String        @id @default(cuid())
  type      LicenseType   @default(LICENSE)
  module    String
  seats     Int?
  status    LicenseStatus @default(ACTIVE)
  expiresAt DateTime?
  client    Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  createdAt DateTime      @default(now())
}
